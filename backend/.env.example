# ==============================
# FlyTire backend environment
# ==============================

PORT=3000

# Telegram (for /api/order and /api/test)
BOT_TOKEN=your_telegram_bot_token
CHAT_ID=your_telegram_chat_id

# ------------------------------
# Gmail IMAP (for /api/tires)
# ------------------------------
# 1) Enable IMAP in Gmail settings
# 2) Use Google App Password (16 chars), not your main password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your_email@gmail.com
IMAP_PASS=your_16_char_app_password

# Sent mailbox in Gmail (works for most accounts)
IMAP_MAILBOX=[Gmail]/Sent Mail

# Optional filters (leave empty to disable)
IMAP_SUBJECT_CONTAINS=price
IMAP_FROM_CONTAINS=your_email@gmail.com
IMAP_ATTACHMENT_NAME_CONTAINS=tires
IMAP_MAX_MESSAGES_TO_SCAN=20
